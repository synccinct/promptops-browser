{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "intent": { "type": "string" },
    "audience": { "type": "string" },
    "constraints": {
      "type": "array",
      "items": { "type": "string" }
    },
    "outputFormat": { "type": "string" },
    "examples": {
      "type": "array",
      "items": { "type": "string" }
    },
    "variables": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "required": { "type": "boolean" },
          "defaultValue": { "type": "string" }
        },
        "required": ["name", "required"]
      }
    }
  },
  "required": ["constraints", "examples", "variables"]
}

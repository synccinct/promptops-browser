{
  "name": "optiprompt",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w @optiprompt/web\" \"npm run dev -w @optiprompt/extension\"",
    "build": "npm run build --workspaces"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.42",
    "concurrently": "^9.2.1",
    "typescript": "^5",
    "zod": "^3.23.8"
  }
}